{% comment %}
  Power Pack Configurator — Shopify Section
  ==========================================
  Built to match the Prestige/Sense OS2 theme conventions used in multi-column.liquid.
  Uses the same section-properties, section-header, section-spacing-collapsing renders,
  CSS variable system, and data-gradient heading pattern as the rest of the theme.

  Installation:
  1. Online Store > Themes > Edit code
  2. Sections > Add a new section > name it "power-pack-configurator"
  3. Paste this file and save
  4. Add to any page via the theme editor
  Submissions go to Shopify Admin > Online Store > Contacts
{% endcomment %}

{%- render 'section-spacing-collapsing' -%}

<div {% render 'section-properties' %}>
  <div class="section-stack">

    {%- render 'section-header'
      , subheading: section.settings.subheading
      , heading: section.settings.title
      , content: section.settings.content
      , text_alignment: section.settings.text_alignment -%}

    <div class="ppc-layout">

      <!-- ── Unit preview ─────────────────────────────────── -->
      <div class="ppc-preview-wrap">
        <div class="ppc-preview">
          <p class="ppc-preview-label">{{ section.settings.preview_label }}</p>

          <svg id="ppc-svg-{{ section.id }}"
            viewBox="0 0 220 285" width="220" height="285"
            xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="20" y="30" width="180" height="225" rx="14" fill="#2a2e28" stroke="#3d4239" stroke-width="1.2"/>
            <rect x="34" y="30" width="152" height="3" rx="1.5" fill="#00E5A0" opacity=".6"/>
            <rect x="20" y="16" width="40" height="14" rx="4" fill="#3d4239"/>
            <rect x="160" y="16" width="40" height="14" rx="4" fill="#3d4239"/>
            <rect x="20" y="30" width="8" height="2" rx="1" fill="#00E5A0" opacity=".4"/>
            <rect x="20" y="30" width="2" height="8" rx="1" fill="#00E5A0" opacity=".4"/>
            <rect x="192" y="30" width="8" height="2" rx="1" fill="#00E5A0" opacity=".4"/>
            <rect x="198" y="30" width="2" height="8" rx="1" fill="#00E5A0" opacity=".4"/>
            <rect x="30" y="42" width="160" height="96" rx="8" fill="#111310"/>
            <rect x="36" y="48" width="148" height="84" rx="6" fill="#0d0f0c"/>
            <circle cx="42" cy="54" r="2" fill="#1e231c"/>
            <circle cx="178" cy="54" r="2" fill="#1e231c"/>
            <text id="ppc-cap-{{ section.id }}" x="110" y="87"
              text-anchor="middle" font-size="22" font-weight="700"
              fill="#00E5A0" font-family="sans-serif">—</text>
            <text x="110" y="106" text-anchor="middle" font-size="10"
              fill="#4a5245" font-family="sans-serif" letter-spacing="2">CAPACITY</text>
            <rect x="30" y="150" width="68" height="46" rx="6" fill="#1e1f4a"/>
            <rect x="34" y="154" width="60" height="38" rx="4" fill="#141530"/>
            <circle cx="64" cy="173" r="10" fill="none" stroke="#5a56c8" stroke-width="1.5"/>
            <line x1="64" y1="163" x2="64" y2="169" stroke="#5a56c8" stroke-width="1.5"/>
            <line x1="64" y1="177" x2="64" y2="183" stroke="#5a56c8" stroke-width="1.5"/>
            <line x1="54" y1="173" x2="60" y2="173" stroke="#5a56c8" stroke-width="1.5"/>
            <line x1="68" y1="173" x2="74" y2="173" stroke="#5a56c8" stroke-width="1.5"/>
            <rect x="108" y="150" width="82" height="46" rx="6" fill="#0d2a1e"/>
            <rect x="112" y="154" width="74" height="38" rx="4" fill="#081a12"/>
            <rect x="120" y="159" width="16" height="26" rx="3" fill="#00b87d"/>
            <rect x="142" y="159" width="6" height="20" rx="2" fill="#00E5A0" opacity=".7"/>
            <rect x="154" y="161" width="6" height="18" rx="2" fill="#00E5A0" opacity=".45"/>
            <text x="64" y="210" text-anchor="middle" font-size="9"
              fill="#6a6eb8" font-family="sans-serif" letter-spacing="1">AC OUTPUT</text>
            <text x="149" y="210" text-anchor="middle" font-size="9"
              fill="#00b87d" font-family="sans-serif" letter-spacing="1">USB / DC</text>
            <rect x="80" y="224" width="60" height="8" rx="4" fill="#1e231c"/>
          </svg>

          <div class="ppc-badge-row" id="ppc-badges-{{ section.id }}"></div>
          <div class="ppc-spec-list" id="ppc-specs-{{ section.id }}"></div>
        </div>
      </div>

      <!-- ── Options ──────────────────────────────────────── -->
      <div class="ppc-options-wrap">
        <div class="ppc-options">

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-cap-sel-{{ section.id }}">Battery capacity</label>
            <select id="ppc-cap-sel-{{ section.id }}" class="ppc-select ppc-trigger">
              <option value="">Select…</option>
              <option value="500Wh">500Wh — compact</option>
              <option value="1kWh">1kWh — standard</option>
              <option value="2kWh">2kWh — extended</option>
              <option value="5kWh">5kWh — high capacity</option>
              <option value="10kWh">10kWh — industrial</option>
            </select>
          </div>

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-vc-{{ section.id }}">Vehicle fast charge</label>
            <select id="ppc-vc-{{ section.id }}" class="ppc-select ppc-trigger">
              <option value="">Not required</option>
              <option value="CCS (DC fast charge)">CCS — DC fast charge</option>
              <option value="CHAdeMO">CHAdeMO</option>
              <option value="Type 2 AC (7kW)">Type 2 AC (7kW)</option>
              <option value="Type 2 AC (22kW)">Type 2 AC (22kW)</option>
            </select>
          </div>

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-wp-{{ section.id }}">Waterproofing</label>
            <select id="ppc-wp-{{ section.id }}" class="ppc-select ppc-trigger">
              <option value="">Standard (indoor)</option>
              <option value="IP54 — splash resistant">IP54 — splash resistant</option>
              <option value="IP65 — dust &amp; jet proof">IP65 — dust &amp; jet proof</option>
              <option value="IP67 — full immersion">IP67 — full immersion</option>
            </select>
          </div>

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-3p-{{ section.id }}">3-phase power output</label>
            <select id="ppc-3p-{{ section.id }}" class="ppc-select ppc-trigger">
              <option value="">Not required</option>
              <option value="3-phase 16A (11kW)">3-phase 16A (11kW)</option>
              <option value="3-phase 32A (22kW)">3-phase 32A (22kW)</option>
              <option value="3-phase 63A (43kW)">3-phase 63A (43kW)</option>
            </select>
          </div>

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-sol-{{ section.id }}">Solar input</label>
            <select id="ppc-sol-{{ section.id }}" class="ppc-select ppc-trigger">
              <option value="">Not required</option>
              <option value="MPPT 400W solar input">MPPT 400W</option>
              <option value="MPPT 800W solar input">MPPT 800W</option>
              <option value="MPPT 1600W solar input">MPPT 1600W</option>
            </select>
          </div>

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-enc-{{ section.id }}">Enclosure &amp; mounting</label>
            <select id="ppc-enc-{{ section.id }}" class="ppc-select ppc-trigger">
              <option value="">Standard casing</option>
              <option value="Rack mount (2U)">Rack mount (2U)</option>
              <option value="Wall mount bracket">Wall mount bracket</option>
              <option value="Wheeled trolley case">Wheeled trolley case</option>
              <option value="Pelican-style hard case">Pelican-style hard case</option>
            </select>
          </div>

          <div class="ppc-field">
            <label class="ppc-label" for="ppc-qty-{{ section.id }}">Quantity required</label>
            <input
              type="number"
              id="ppc-qty-{{ section.id }}"
              class="ppc-select ppc-trigger ppc-qty"
              min="1" max="9999"
              placeholder="e.g. 5"
              value="1"
            />
          </div>

          <button type="button" class="ppc-cta button" id="ppc-open-{{ section.id }}">
            {{ section.settings.cta_text }}
          </button>

        </div>
      </div>

    </div><!-- /.ppc-layout -->
  </div><!-- /.section-stack -->
</div>

<!-- ═══════════ MODAL ═══════════ -->
<div class="ppc-modal-bg" id="ppc-modal-bg-{{ section.id }}"
  role="dialog" aria-modal="true" aria-label="Send enquiry">
  <div class="ppc-modal">

    <p class="ppc-modal-title h2">{{ section.settings.modal_title }}</p>
    <div id="ppc-modal-specs-{{ section.id }}" class="ppc-modal-specs"></div>

    <form
      method="post"
      action="/contact#ppc-form-{{ section.id }}"
      id="ppc-form-{{ section.id }}"
      accept-charset="UTF-8"
    >
      <input type="hidden" name="form_type" value="contact"/>
      <input type="hidden" name="utf8" value="✓"/>
      <input type="hidden" name="contact[body]" id="ppc-hidden-{{ section.id }}"/>

      <div class="ppc-cfields">
        <div class="ppc-cfield">
          <label class="ppc-clabel" for="ppc-cname-{{ section.id }}">Your name</label>
          <input type="text" id="ppc-cname-{{ section.id }}"
            name="contact[name]" class="ppc-cinput" placeholder="Jane Smith" required/>
        </div>
        <div class="ppc-cfield">
          <label class="ppc-clabel" for="ppc-cemail-{{ section.id }}">Email address</label>
          <input type="email" id="ppc-cemail-{{ section.id }}"
            name="contact[email]" class="ppc-cinput" placeholder="jane@company.com" required/>
        </div>
        <div class="ppc-cfield">
          <label class="ppc-clabel" for="ppc-cnotes-{{ section.id }}">Additional notes</label>
          <textarea id="ppc-cnotes-{{ section.id }}"
            name="contact[notes]" class="ppc-cinput ppc-ctextarea"
            placeholder="Delivery timeline, site requirements, etc."></textarea>
        </div>
      </div>

      <div class="ppc-mfoot">
        <button type="button" class="button button--subdued" id="ppc-close-{{ section.id }}">Back</button>
        <button type="submit" class="button">Send enquiry</button>
      </div>
    </form>

    {%- if section.settings.show_modal_note -%}
      <p class="ppc-modal-note prose">{{ section.settings.modal_note }}</p>
    {%- endif -%}

  </div>
</div>

{%- comment -%} ═══════ STYLES ═══════ {%- endcomment -%}
<style>
  /* ── Layout ──────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .ppc-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-12);
    align-items: start;
  }
  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .ppc-layout {
      grid-template-columns: 1fr;
    }
  }

  /* ── Preview panel ───────────────────────────────────── */
  #shopify-section-{{ section.id }} .ppc-preview {
    background: {{ section.settings.unit_bg }};
    border-radius: var(--block-border-radius, 8px);
    padding: var(--spacing-8, 2rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-4, 1rem);
  }
  #shopify-section-{{ section.id }} .ppc-preview-label {
    align-self: flex-start;
    font-size: var(--text-xs, 11px);
    font-weight: var(--text-font-bolder-weight, 700);
    letter-spacing: .1em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0;
  }
  #shopify-section-{{ section.id }} .ppc-badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2, 6px);
    justify-content: center;
    min-height: 1.5rem;
  }
  #shopify-section-{{ section.id }} .ppc-badge {
    font-size: var(--text-xs, 11px);
    font-weight: var(--text-font-bolder-weight, 700);
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 20px;
  }
  #shopify-section-{{ section.id }} .ppc-badge--t { background: rgba(0,229,160,.15); color: #00E5A0; border: 1px solid rgba(0,229,160,.35); }
  #shopify-section-{{ section.id }} .ppc-badge--b { background: rgba(56,138,221,.15); color: #7BC2F5; border: 1px solid rgba(56,138,221,.35); }
  #shopify-section-{{ section.id }} .ppc-badge--p { background: rgba(127,119,221,.15); color: #BDB8F5; border: 1px solid rgba(127,119,221,.35); }
  #shopify-section-{{ section.id }} .ppc-badge--y { background: rgba(239,159,39,.15); color: #F5C97A; border: 1px solid rgba(239,159,39,.35); }
  #shopify-section-{{ section.id }} .ppc-badge--c { background: rgba(216,90,48,.15); color: #F5A07A; border: 1px solid rgba(216,90,48,.35); }
  #shopify-section-{{ section.id }} .ppc-spec-list {
    width: 100%;
    font-size: var(--text-xs, 12px);
    border-top: 1px solid rgba(255,255,255,.1);
    padding-top: var(--spacing-3, 10px);
  }
  #shopify-section-{{ section.id }} .ppc-spec-row {
    display: flex;
    justify-content: space-between;
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,.07);
    color: rgba(255,255,255,.45);
  }
  #shopify-section-{{ section.id }} .ppc-spec-row:last-child { border-bottom: none; }
  #shopify-section-{{ section.id }} .ppc-spec-val {
    font-weight: var(--text-font-bolder-weight, 600);
    color: rgba(255,255,255,.85);
    text-align: right;
    max-width: 60%;
  }

  /* ── Options panel ───────────────────────────────────── */
  #shopify-section-{{ section.id }} .ppc-options {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4, 1rem);
  }
  #shopify-section-{{ section.id }} .ppc-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2, 5px);
  }
  #shopify-section-{{ section.id }} .ppc-label {
    font-size: var(--text-xs, 11px);
    font-weight: var(--text-font-bolder-weight, 700);
    letter-spacing: .07em;
    text-transform: uppercase;
    color: currentColor;
    opacity: .65;
  }
  #shopify-section-{{ section.id }} .ppc-select {
    width: 100%;
    font-size: var(--text-sm, 13px);
    padding: 10px 12px;
    border: 1px solid rgba(currentColor, .2);
    border-radius: var(--input-border-radius, 4px);
    background: transparent;
    color: currentColor;
    appearance: auto;
  }
  #shopify-section-{{ section.id }} .ppc-qty { width: 120px; }
  #shopify-section-{{ section.id }} .ppc-cta {
    align-self: stretch;
    margin-top: var(--spacing-2, 4px);
  }

  /* ── Modal ───────────────────────────────────────────── */
  .ppc-modal-bg {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.55);
    z-index: 10000;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-5, 1.25rem);
  }
  .ppc-modal-bg.is-open { display: flex; }
  .ppc-modal {
    background: rgb(var(--color-background));
    border-radius: var(--block-border-radius, 8px);
    border-top: 3px solid {{ section.settings.accent_color }};
    padding: var(--spacing-8, 2rem);
    width: min(520px, 100%);
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: var(--shadow-block-outer);
  }
  .ppc-modal-title {
    margin-bottom: var(--spacing-5, 1.25rem) !important;
  }
  .ppc-modal-specs {
    margin-bottom: var(--spacing-5, 1.25rem);
    border: 1px solid rgba(currentColor, .12);
    border-radius: var(--block-border-radius, 6px);
    overflow: hidden;
  }
  .ppc-mrow {
    display: flex;
    justify-content: space-between;
    padding: 9px 14px;
    font-size: var(--text-sm, 14px);
    border-bottom: 1px solid rgba(currentColor, .08);
  }
  .ppc-mrow:last-child { border-bottom: none; }
  .ppc-mrow:nth-child(odd) { background: rgba(currentColor, .02); }
  .ppc-mk { opacity: .55; }
  .ppc-mv { font-weight: var(--text-font-bolder-weight, 600); text-align: right; }
  .ppc-cfields {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4, 1rem);
  }
  .ppc-cfield {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2, 5px);
  }
  .ppc-clabel {
    font-size: var(--text-xs, 11px);
    font-weight: var(--text-font-bolder-weight, 700);
    letter-spacing: .07em;
    text-transform: uppercase;
    opacity: .6;
  }
  .ppc-cinput {
    width: 100%;
    font-size: var(--text-sm, 14px);
    padding: 10px 12px;
    border: 1px solid rgba(currentColor, .2);
    border-radius: var(--input-border-radius, 4px);
    background: transparent;
    color: currentColor;
  }
  .ppc-ctextarea {
    resize: vertical;
    min-height: 80px;
  }
  .ppc-mfoot {
    display: flex;
    gap: var(--spacing-3, .75rem);
    margin-top: var(--spacing-6, 1.5rem);
  }
  .ppc-mfoot .button { flex: 1; justify-content: center; }
  .ppc-modal-note {
    margin-top: var(--spacing-4, 1rem);
    font-size: var(--text-xs, 12px);
    opacity: .55;
    text-align: center;
  }
</style>

{%- comment -%} ═══════ JAVASCRIPT ═══════ {%- endcomment -%}
<script>
(function () {
  var sid = '{{ section.id }}';
  var capColors = {
    '500Wh': '#00E5A0', '1kWh': '#00E5A0',
    '2kWh':  '#8BE5A0', '5kWh': '#F5C97A', '10kWh': '#F5907A'
  };

  function el(id) { return document.getElementById(id); }
  function sv(id) { var e = el(id); return e ? e.value : ''; }

  function getSpecs() {
    return {
      cap:   sv('ppc-cap-sel-' + sid),
      vc:    sv('ppc-vc-'      + sid),
      wp:    sv('ppc-wp-'      + sid),
      three: sv('ppc-3p-'      + sid),
      sol:   sv('ppc-sol-'     + sid),
      enc:   sv('ppc-enc-'     + sid),
      qty:   sv('ppc-qty-'     + sid) || '1'
    };
  }

  function updatePreview() {
    var s  = getSpecs();
    var cl = el('ppc-cap-' + sid);
    if (s.cap) { cl.textContent = s.cap; cl.setAttribute('fill', capColors[s.cap] || '#00E5A0'); }
    else       { cl.textContent = '—';  cl.setAttribute('fill', '#2a3a2a'); }

    var br = el('ppc-badges-' + sid);
    br.innerHTML = '';
    var feats = [];
    if (s.vc)    feats.push({ t: s.vc,    c: 't' });
    if (s.wp)    feats.push({ t: s.wp,    c: 'b' });
    if (s.three) feats.push({ t: s.three, c: 'p' });
    if (s.sol)   feats.push({ t: s.sol,   c: 'y' });
    if (s.enc && s.enc !== 'Standard casing') feats.push({ t: s.enc, c: 'c' });
    feats.forEach(function (f) {
      var b = document.createElement('span');
      b.className  = 'ppc-badge ppc-badge--' + f.c;
      b.textContent = f.t;
      br.appendChild(b);
    });

    var sl   = el('ppc-specs-' + sid);
    var rows = [];
    if (s.cap)   rows.push(['Capacity',       s.cap]);
    if (s.vc)    rows.push(['Vehicle charge',  s.vc]);
    if (s.wp)    rows.push(['Waterproofing',   s.wp]);
    if (s.three) rows.push(['3-phase output',  s.three]);
    if (s.sol)   rows.push(['Solar input',     s.sol]);
    if (s.enc)   rows.push(['Enclosure',       s.enc]);
    rows.push(['Quantity', s.qty]);
    sl.innerHTML = rows.map(function (r) {
      return '<div class="ppc-spec-row"><span>' + r[0] + '</span>'
           + '<span class="ppc-spec-val">' + r[1] + '</span></div>';
    }).join('');
  }

  /* Attach listeners */
  var section = document.getElementById('shopify-section-' + sid);
  if (section) {
    section.querySelectorAll('.ppc-trigger').forEach(function (input) {
      input.addEventListener('change', updatePreview);
      input.addEventListener('input',  updatePreview);
    });
  }

  /* Open modal */
  el('ppc-open-' + sid).addEventListener('click', function () {
    var s = getSpecs();
    var rows = [
      ['Battery capacity',    s.cap   || 'Not specified'],
      ['Vehicle fast charge', s.vc    || 'Not required'],
      ['Waterproofing',       s.wp    || 'Standard (indoor)'],
      ['3-phase power',       s.three || 'Not required'],
      ['Solar input',         s.sol   || 'Not required'],
      ['Enclosure',           s.enc   || 'Standard casing'],
      ['Quantity',            s.qty]
    ];
    el('ppc-modal-specs-' + sid).innerHTML = rows.map(function (r) {
      return '<div class="ppc-mrow"><span class="ppc-mk">' + r[0]
           + '</span><span class="ppc-mv">' + r[1] + '</span></div>';
    }).join('');
    el('ppc-modal-bg-' + sid).classList.add('is-open');
    document.body.style.overflow = 'hidden';
  });

  /* Close modal */
  function closeModal() {
    el('ppc-modal-bg-' + sid).classList.remove('is-open');
    document.body.style.overflow = '';
  }
  el('ppc-close-' + sid).addEventListener('click', closeModal);
  el('ppc-modal-bg-' + sid).addEventListener('click', function (e) {
    if (e.target === this) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });

  /* Build email body on submit */
  el('ppc-form-' + sid).addEventListener('submit', function () {
    var s     = getSpecs();
    var notes = el('ppc-cnotes-' + sid).value;
    el('ppc-hidden-' + sid).value = [
      'POWER PACK ENQUIRY',
      '──────────────────────────────────',
      'SPECIFICATIONS:',
      'Battery capacity: '    + (s.cap   || 'Not specified'),
      'Vehicle fast charge: ' + (s.vc    || 'Not required'),
      'Waterproofing: '       + (s.wp    || 'Standard (indoor)'),
      '3-phase power: '       + (s.three || 'Not required'),
      'Solar input: '         + (s.sol   || 'Not required'),
      'Enclosure: '           + (s.enc   || 'Standard casing'),
      'Quantity: '            + s.qty,
      '──────────────────────────────────',
      'Notes: '               + (notes || '—')
    ].join('\n');
  });

  updatePreview();
})();
</script>

{% schema %}
{
  "name": "Power pack configurator",
  "class": "shopify-section--power-pack-configurator",
  "tag": "section",
  "disabled_on": {
